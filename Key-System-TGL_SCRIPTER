<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TGL_SCRIPTER - Key Generator</title>
    <style>
        body {
            background-color: #0f0f14;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #1a1a24;
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
            border: 2px solid #333;
            max-width: 400px;
            width: 90%;
        }
        h1 { margin-bottom: 20px; font-size: 24px; color: #fff; }
        .key-box {
            background-color: #0f0f14;
            padding: 15px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 20px;
            margin: 20px 0;
            border: 1px solid #444;
            color: #00ff00;
            word-break: break-all;
        }
        .btn {
            background-color: #2a5a2a;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }
        .btn:hover { background-color: #3a7a3a; }
        .info { color: #888; font-size: 12px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>TGL_SCRIPTER</h1>
        <p>Your unique key for today is:</p>
        <div class="key-box" id="key-display">Loading...</div>
        <button class="btn" onclick="copyKey()">Copy Key</button>
        <p class="info">This key is unique to your device and expires in 24 hours.</p>
    </div>

    <script>
        const SALT = "TGL_ULTIMATE_SECURITY_99";

        function generateKey() {
            const urlParams = new URLSearchParams(window.location.search);
            const hwid = urlParams.get('hwid') || "GUEST";
            
            const date = new Date();
            // Create a seed based on UTC Date + HWID + Salt
            const seed = date.getUTCDate() + "" + (date.getUTCMonth() + 1) + "" + date.getUTCFullYear() + hwid + SALT;
            
            let hash = 0;
            for (let i = 0; i < seed.length; i++) {
                hash = (hash * 31 + seed.charCodeAt(i)) % 9999999;
            }
            return "TGL-" + Math.abs(hash);
        }

        const currentKey = generateKey();
        document.getElementById("key-display").innerText = currentKey;

        function copyKey() {
            navigator.clipboard.writeText(currentKey);
            alert("Key copied to clipboard!");
        }
    </script>
</body>
